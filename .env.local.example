# ============================================================
#  Dar Nahl – Environment Variables
#  Copy this file to .env.local and fill in your values.
# ============================================================

# ── Supabase ────────────────────────────────────────────────
# Create a free project at https://supabase.com
# Then go to: Project Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Setup Steps ─────────────────────────────────────────────
# 1. Create a Supabase project (free tier is sufficient)
# 2. Open the SQL Editor and run the file: supabase/schema.sql
# 3. Go to Authentication → Users → Add User (manual)
#    Create the admin account with your email and password
# 4. Copy the URL and anon key above from Project Settings → API
# 5. Rename this file to .env.local

# ── Notes ───────────────────────────────────────────────────
# - Without these vars, the app runs in DEMO MODE (read-only mock data)
# - Demo mode is perfect for previewing the UI before Supabase setup
# - The anon key is safe to expose in the browser (RLS protects your data)
